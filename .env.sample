# Server Configuration
SERVER_PORT=8080
SERVER_HOST=127.0.0.1

# API Configuration (if needed for future extensions)
API_TIMEOUT=30
MAX_REQUESTS_PER_MINUTE=100

# Security Secrets
API_SECRET_KEY=your-super-secret-key-change-this-in-production
ADMIN_TOKEN=your-admin-token-change-this

# Environment
RUST_ENV=development
LOG_LEVEL=debug